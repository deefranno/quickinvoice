# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
JWT_SECRET=change_this_to_a_random_secret_string_min_32_chars
ADMIN_JWT_SECRET=change_this_to_a_different_random_string

# ─── Database ──────────────────────────────────────────
# Production (Railway): Set this to your Railway volume mount path for persistence
# In Railway Dashboard: Add a Volume → set mount path to /data → set DB_PATH=/data
# If left blank, /tmp is used (data lost on restart)
DB_PATH=

# ─── Stripe (optional — leave blank to disable) ────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=

# ─── WiPay (optional — leave blank to disable) ─────────
WIPAY_ACCOUNT_NUMBER=
WIPAY_API_KEY=
WIPAY_COUNTRY_CODE=TT
WIPAY_ENVIRONMENT=sandbox
WIPAY_FEE_STRUCTURE=customer_pay

# ─── Ezee (optional — leave blank to disable) ──────────
EZEE_MERCHANT_ID=
EZEE_API_KEY=
EZEE_SECRET_KEY=
EZEE_ENVIRONMENT=sandbox

# ─── Email (optional — logs to console if blank) ───────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@quickinvoice.app

# ─── Admin ─────────────────────────────────────────────
ADMIN_EMAIL=admin@quickinvoice.app

# ─── Background Jobs ───────────────────────────────────
ENABLE_JOBS=false
